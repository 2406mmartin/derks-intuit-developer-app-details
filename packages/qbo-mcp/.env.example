# Intuit Developer app credentials (production keys for live company data).
# Create an app at https://developer.intuit.com -> My Apps -> Keys & OAuth.
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=

# "sandbox" or "production". Keep these in sync with the Intuit keys above.
QBO_ENVIRONMENT=production

# OAuth redirect URI. Must match exactly what's registered in the Intuit app.
# Loopback addresses are allowed for production apps.
QBO_REDIRECT_URI=http://localhost:8723/callback
QBO_CALLBACK_PORT=8723

# Where encrypted tokens + the AES key live. Defaults to ~/.qbo-mcp/
# QBO_DATA_DIR=/Users/you/.qbo-mcp
